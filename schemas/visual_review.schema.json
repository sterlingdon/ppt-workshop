{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "project_id",
    "review_type",
    "gate_type",
    "status",
    "review_context",
    "review_capability",
    "blocking_findings",
    "slides"
  ],
  "properties": {
    "project_id": { "type": "string", "minLength": 1 },
    "review_type": { "type": "string", "const": "ai_lens_visual_review" },
    "gate_type": { "type": "string", "const": "ai_visual_quality_review" },
    "status": { "type": "string", "enum": ["pass", "blocked"] },
    "review_assets": {
      "type": "object",
      "required": ["full_deck_screenshot", "slide_screenshots_dir"],
      "properties": {
        "full_deck_screenshot": { "type": "string", "minLength": 1 },
        "slide_screenshots_dir": { "type": "string", "minLength": 1 }
      }
    },
    "review_context": {
      "type": "object",
      "required": ["context_sources", "rubric_version", "critical_slide_policy_version"],
      "properties": {
        "context_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "rubric_version": { "type": "string", "minLength": 1 },
        "critical_slide_policy_version": { "type": "string", "minLength": 1 }
      }
    },
    "review_capability": {
      "type": "object",
      "required": ["method", "image_input", "inspected_assets"],
      "properties": {
        "method": { "type": "string", "enum": ["vision_model", "human_visual_review"] },
        "image_input": { "type": "boolean" },
        "model": { "type": "string" },
        "inspected_assets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "notes": { "type": "string" }
      }
    },
    "blocking_findings": { "type": "integer", "minimum": 0 },
    "repair_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "changed_artifacts": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "string" }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slide",
          "passed",
          "visual_score",
          "visual_craft_score",
          "strategic_clarity_score",
          "findings",
          "repairs",
          "hard_blockers"
        ],
        "properties": {
          "slide": { "type": "integer", "minimum": 1 },
          "passed": { "type": "boolean" },
          "visual_score": { "type": "integer", "minimum": 1, "maximum": 10 },
          "visual_craft_score": { "type": "number", "minimum": 1, "maximum": 10 },
          "strategic_clarity_score": { "type": "number", "minimum": 1, "maximum": 10 },
          "critical_visual": { "type": "boolean" },
          "wow_passed": { "type": "boolean" },
          "review_scope": { "type": "string", "enum": ["slide_local", "pattern_shared", "deck_global"] },
          "rollback_recommendation": { "type": "string" },
          "criteria_scores": { "type": "object" },
          "findings": { "type": "array" },
          "repairs": { "type": "array" },
          "hard_blockers": { "type": "array" }
        }
      }
    }
  }
}
