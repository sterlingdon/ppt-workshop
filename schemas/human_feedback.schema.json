{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "feedback_scope",
          "targets",
          "reason",
          "expected_change",
          "rollback_level",
          "restart_stage",
          "invalidated_artifacts",
          "agent_acknowledgement",
          "status"
        ],
        "properties": {
          "feedback_scope": { "type": "string", "minLength": 1 },
          "targets": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "reason": { "type": "string", "minLength": 1 },
          "expected_change": { "type": "string", "minLength": 1 },
          "rollback_level": {
            "type": "string",
            "enum": ["slide_local", "pattern_shared", "deck_global"]
          },
          "restart_stage": { "type": "string", "minLength": 1 },
          "invalidated_artifacts": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "agent_acknowledgement": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["open", "acknowledged", "resolved", "rejected"]
          }
        }
      }
    }
  }
}
