{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["slides"],
  "properties": {
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slide", "asset_slots"],
        "properties": {
          "slide": { "type": "integer", "minimum": 1 },
          "asset_slots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["slot", "primary_route"],
              "properties": {
                "slot": { "type": "string", "minLength": 1 },
                "primary_route": {
                  "type": "string",
                  "enum": ["diagram/svg", "chart", "image_search", "image_generation", "none"]
                },
                "fallback_routes": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["diagram/svg", "chart", "image_search", "image_generation", "none"]
                  }
                },
                "candidate_count": { "type": "integer", "minimum": 1 },
                "independent_asset_review": { "type": "boolean" },
                "critical_visual": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
