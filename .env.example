# Visual asset providers
#
# Copy to `.env` and fill only the providers you plan to use.
# Leaving a provider unset is valid; the corresponding asset route will remain blocked.

# Search providers
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Optional: force a specific search provider instead of auto-picking the first configured one.
# Supported: unsplash, pexels, pixabay
VISUAL_ASSET_SEARCH_PROVIDER=

# Image generation providers
GEMINI_API_KEY=
QWEN_IMAGE_API_KEY=
WANX_API_KEY=

# Optional DashScope fallback for Qwen / Wanx if you don't want separate keys above.
DASHSCOPE_API_KEY=

# Optional: force a specific image provider instead of auto-picking the first configured one.
# Supported: gemini, qwen, wanx
VISUAL_ASSET_IMAGE_PROVIDER=

# Optional model overrides
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
QWEN_IMAGE_MODEL=qwen-image-2.0-pro
WANX_IMAGE_MODEL=wan2.6-t2i

# Optional API base overrides
QWEN_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
WANX_IMAGE_BASE_URL=

# Optional size overrides
QWEN_IMAGE_SIZE=1024*1024
WANX_IMAGE_SIZE=1024*1024
